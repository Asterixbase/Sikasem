# Sikasem Production Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# Generate SECRET_KEY with: openssl rand -hex 64

# ── App ──────────────────────────────────────────
APP_NAME=Sikasem
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64_MINIMUM_64_CHARS

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-settings-api
DATABASE_URL=postgresql+asyncpg://postgres:password@db.YOURPROJECT.supabase.co:5432/postgres

# ── MTN MoMo ─────────────────────────────────────
MOMO_ENVIRONMENT=sandbox
MOMO_COLLECTION_PRIMARY_KEY=
MOMO_COLLECTION_SECONDARY_KEY=
MOMO_COLLECTION_USER_ID=
MOMO_COLLECTION_API_KEY=
MOMO_DISBURSEMENT_PRIMARY_KEY=
MOMO_DISBURSEMENT_SECONDARY_KEY=
MOMO_DISBURSEMENT_USER_ID=
MOMO_DISBURSEMENT_API_KEY=
MOMO_CALLBACK_HOST=https://api.sikasem.gh
MOMO_WEBHOOK_SECRET=CHANGE_ME_MOMO_HMAC_SECRET

# ── Insurance ─────────────────────────────────────
GLICO_API_URL=https://api.glico.com.gh/v1
GLICO_API_KEY=
GLICO_PARTNER_ID=SKS001
ENTLIFE_API_URL=https://api.enterpriselife.com.gh/v1
ENTLIFE_API_KEY=
ENTLIFE_PARTNER_ID=SKS001

# ── USSD (Africa's Talking) ───────────────────────
USSD_PROVIDER=africastalking
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_WEBHOOK_SECRET=

# ── WhatsApp (Twilio) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Push Notifications ───────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ── Observability ─────────────────────────────────
SENTRY_DSN=

# ── Bank of Ghana ─────────────────────────────────
BOG_SANDBOX_URL=https://sandbox.bog.gov.gh/v1
BOG_API_KEY=
