# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection string (Session mode on port 5432)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-64-char-hex-string
JWT_EXPIRE_DAYS=7

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# In development: OTP is logged to console, code 000000 always passes
# In production: real Twilio SMS is sent

# ── Twilio (required in production for real SMS OTP) ──────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Redis (for rate limiting — optional, falls back to in-memory) ─────────────
REDIS_URL=redis://localhost:6379/0

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── CORS & Hosts ──────────────────────────────────────────────────────────────
ALLOWED_HOSTS=api.sikasem.app,localhost
CORS_ORIGINS=http://localhost:3000,https://sikasem.app

# ── Anthropic (Claude Vision OCR — invoice, ID card, bulk scan) ──────────────
ANTHROPIC_API_KEY=

# ── MTN MoMo (stub — wire in when account is ready) ──────────────────────────
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_ENVIRONMENT=sandbox
